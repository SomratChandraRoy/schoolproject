# Frontend API base URL
# Development example: http://localhost:8000
# Production (same domain as API behind nginx): leave empty
# Do not include trailing slash
VITE_API_URL=http://localhost:8000

# Optional fallback app id for video-call diagnostics/bootstrap.
# Example: vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_JAAS_APP_ID=

# WorkOS public client config (safe in frontend)
VITE_WORKOS_CLIENT_ID=client_REDACTED
VITE_WORKOS_REDIRECT_URI=http://localhost:5173/auth/callback

# Optional frontend Stripe key (checkout is server-driven, but this helps diagnostics)
VITE_STRIPE_PUBLISHABLE_KEY=

# Frontend Sentry (optional but recommended for production)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# CI/CD can inject commit SHA here
VITE_APP_RELEASE=

# Frontend Gemini key (optional, only if used by frontend features)
VITE_GEMINI_API_KEY=your_frontend_gemini_key_here
REACT_APP_ELEVENLABS_AGENT_ID=your-agent-id-here
VITE_TLDRAW_LICENSE_KEY=your-tldraw-license-key-here