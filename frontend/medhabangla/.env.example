# Frontend API base URL
VITE_API_URL=http://localhost:8000

# WorkOS public client config (safe in frontend)
VITE_WORKOS_CLIENT_ID=client_REDACTED
VITE_WORKOS_REDIRECT_URI=http://localhost:5173/auth/callback

# Frontend Gemini key (optional, only if used by frontend features)
VITE_GEMINI_API_KEY=your_frontend_gemini_key_here
REACT_APP_ELEVENLABS_AGENT_ID=your-agent-id-here