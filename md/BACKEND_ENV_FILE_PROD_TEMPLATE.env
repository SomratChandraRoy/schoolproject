# Production BACKEND_ENV_FILE template for GitHub Actions secret
# Paste the full content of this file into repository secret: BACKEND_ENV_FILE
# This template targets current Kubernetes manifests in this repository.
# IMPORTANT: Rotate any previously exposed Google service-account key before use.

# =========================
# Django Core
# =========================
DEBUG=False
DJANGO_SECRET_KEY=REPLACE_WITH_STRONG_DJANGO_SECRET
ALLOWED_HOSTS=bipulroy.me,www.bipulroy.me
FRONTEND_URL=https://bipulroy.me

# Optional admin bootstrap (recommended: keep disabled and create admin manually)
AUTO_CREATE_SUPERUSER=False
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=admin@medhabangla.local

# =========================
# Runtime / Kubernetes
# =========================
DOCKER_ENV=True
USE_SQLITE=False

# =========================
# PostgreSQL (in-cluster)
# =========================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=medhabangla_db
DB_USER=medhabangla_user
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_CONN_MAX_AGE=300
DB_SSLMODE=prefer
DB_SSLROOTCERT=
DB_CONNECT_TIMEOUT=10

# =========================
# Redis / Channels
# =========================
REDIS_URL=redis://redis:6379/0

# =========================
# Security / CORS / CSRF
# =========================
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://bipulroy.me,https://www.bipulroy.me
CSRF_TRUSTED_ORIGINS=https://bipulroy.me,https://www.bipulroy.me
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# =========================
# Sentry Monitoring
# =========================
SENTRY_DSN=REPLACE_WITH_BACKEND_SENTRY_DSN
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.15
SENTRY_PROFILES_SAMPLE_RATE=0.0

# =========================
# WorkOS OAuth
# =========================
WORKOS_API_KEY=REPLACE_WITH_WORKOS_API_KEY
WORKOS_CLIENT_ID=REPLACE_WITH_WORKOS_CLIENT_ID
WORKOS_REDIRECT_URI=https://bipulroy.me/auth/callback

# =========================
# Stripe Payments
# =========================
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
STRIPE_SUCCESS_URL=https://bipulroy.me/plans
STRIPE_CANCEL_URL=https://bipulroy.me/plans

# =========================
# AI Providers
# =========================
GROQ_API_KEY=REPLACE_WITH_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile
ALIBABA_API_KEY=REPLACE_WITH_ALIBABA_API_KEY
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY
GEMINI_API_KEYS=
DEEPGRAM_API_KEY=REPLACE_WITH_DEEPGRAM_API_KEY
SARVAM_API_KEY=REPLACE_WITH_SARVAM_API_KEY

VOICE_QWEN_MODEL=qwen-turbo
VOICE_GROQ_MODEL=llama-3.3-70b-versatile

DEEPGRAM_STT_URL=https://api.deepgram.com/v1/listen
DEEPGRAM_STT_MODEL=general
DEEPGRAM_STT_LANGUAGE=bn
DEEPGRAM_STT_TIER=nova-3

SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_STT_LANGUAGE=bn-IN
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
SARVAM_TTS_LANGUAGE=bn-IN
SARVAM_TTS_SPEAKER=anushka

GEMINI_TTS_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent
GEMINI_TTS_VOICE=Kore

# =========================
# 8x8 JaaS
# =========================
JAAS_DOMAIN=8x8.vc
JAAS_APP_ID=REPLACE_WITH_JAAS_APP_ID
JAAS_KID=REPLACE_WITH_JAAS_KID
JAAS_PRIVATE_KEY=REPLACE_WITH_JAAS_PRIVATE_KEY_WITH_ESCAPED_NEWLINES
JAAS_JWT_TTL_SECONDS=3600
JAAS_REQUIRE_AUTH_TOKEN=False

# =========================
# Google Drive PDF Storage
# =========================
USE_GOOGLE_DRIVE=True
# Keep as ONE-LINE JSON, no outer single quotes.
# Keep private_key line breaks escaped as \n
GOOGLE_DRIVE_CREDENTIALS_JSON={"type":"service_account","project_id":"sopna-493414","private_key_id":"REPLACE_WITH_NEW_PRIVATE_KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_NEW_PRIVATE_KEY\n-----END PRIVATE KEY-----\n","client_email":"drive-manager@sopna-493414.iam.gserviceaccount.com","client_id":"101235849990498600496","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/drive-manager%40sopna-493414.iam.gserviceaccount.com","universe_domain":"googleapis.com"}
GOOGLE_DRIVE_FOLDER_ID=1E5H74WdSFMXRP7V-at5GC8oqShP_6fZR
GOOGLE_DRIVE_BOOKS_FOLDER_ID=1E5H74WdSFMXRP7V-at5GC8oqShP_6fZR
GOOGLE_DRIVE_PUBLIC_FILES=True

# Optional upload limits (bytes)
DATA_UPLOAD_MAX_MEMORY_SIZE=262144000
FILE_UPLOAD_MAX_MEMORY_SIZE=26214400

# =========================
# Optional Voice Fallback
# =========================
ELEVENLABS_API_KEY=
ELEVENLABS_API=
