# =========================
# Django Core
# =========================
DEBUG=False
DJANGO_SECRET_KEY=change_me_with_a_strong_secret
ALLOWED_HOSTS=bipulroy.me,www.bipulroy.me
FRONTEND_URL=https://bipulroy.me

# =========================
# Runtime / Docker
# =========================
DOCKER_ENV=True
USE_SQLITE=False

# =========================
# PostgreSQL
# =========================
# For Docker local DB use DB_HOST=db.
# For DigitalOcean Managed PostgreSQL set DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD
# from your DO database connection details.
DB_HOST=db
DB_PORT=5432
DB_NAME=medhabangla_db
DB_USER=medhabangla_user
DB_PASSWORD=change_this_postgres_password
DB_CONN_MAX_AGE=300

# PostgreSQL SSL settings.
# For DigitalOcean Managed PostgreSQL use DB_SSLMODE=require
DB_SSLMODE=prefer
# Optional CA path inside container (advanced)
DB_SSLROOTCERT=
DB_CONNECT_TIMEOUT=10

# =========================
# Redis / Channels
# =========================
REDIS_URL=redis://redis:6379/0

# =========================
# Security / CORS / CSRF
# =========================
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://bipulroy.me,https://www.bipulroy.me
CSRF_TRUSTED_ORIGINS=https://bipulroy.me,https://www.bipulroy.me

# Keep False when TLS is terminated externally (for example DigitalOcean LB).
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# =========================
# WorkOS OAuth
# =========================
WORKOS_API_KEY=your_workos_api_key
WORKOS_CLIENT_ID=your_workos_client_id
WORKOS_REDIRECT_URI=https://bipulroy.me/auth/callback

# =========================
# Stripe Payments
# =========================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Stripe CLI/dev webhook secret or production endpoint secret
STRIPE_WEBHOOK_SECRET=
# Redirect URLs after checkout
STRIPE_SUCCESS_URL=https://bipulroy.me/plans
STRIPE_CANCEL_URL=https://bipulroy.me/plans

# =========================
# AI Providers
# =========================
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

ALIBABA_API_KEY=your_alibaba_dashscope_api_key

GEMINI_API_KEY=your_gemini_api_key
# Optional multiple keys: key1,key2,key3
GEMINI_API_KEYS= 

DEEPGRAM_API_KEY=your_deepgram_api_key
SARVAM_API_KEY=your_sarvam_api_key

VOICE_QWEN_MODEL=qwen-turbo
VOICE_GROQ_MODEL=llama-3.3-70b-versatile

DEEPGRAM_STT_URL=https://api.deepgram.com/v1/listen
DEEPGRAM_STT_MODEL=general
DEEPGRAM_STT_LANGUAGE=bn

SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_STT_LANGUAGE=bn-IN
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
SARVAM_TTS_LANGUAGE=bn-IN
SARVAM_TTS_SPEAKER=anushka

GEMINI_TTS_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent
GEMINI_TTS_VOICE=Kore

# =========================
# 8x8 JaaS
# =========================
JAAS_DOMAIN=8x8.vc
JAAS_APP_ID=
JAAS_KID=
# Keep new lines as escaped \n when pasted here.
JAAS_PRIVATE_KEY=
JAAS_JWT_TTL_SECONDS=3600
JAAS_REQUIRE_AUTH_TOKEN=False

# =========================
# Google Drive Chat Storage
# =========================
USE_GOOGLE_DRIVE=False
GOOGLE_DRIVE_CREDENTIALS_JSON=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_PUBLIC_FILES=True

# =========================
# Optional Voice Fallback
# =========================
ELEVENLABS_API_KEY=
ELEVENLABS_API=