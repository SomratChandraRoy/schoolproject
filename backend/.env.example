# Django Configuration
DEBUG=True
SECRET_KEY=django-insecure-REDACTED
ALLOWED_HOSTS=*
DOCKER_ENV=False

# Database Configuration (for Docker)
# DATABASE_URL=postgresql://medhabangla_user:medhabangla_password@db:5432/medhabangla_db

# AWS RDS PostgreSQL Configuration
# Uncomment and configure for AWS RDS
# DB_HOST=medhabangla-db.c34euac6613f.eu-north-1.rds.amazonaws.com
# DB_NAME=medhabangla
# DB_USER=postgres
# DB_PASSWORD=REDACTED
# DB_PORT=5432
# DB_CONN_MAX_AGE=300  # Connection pooling: keep connections alive for 5 minutes (default: 300)

# SQLite Configuration (for local development)
# Uncomment to use SQLite instead of PostgreSQL
# USE_SQLITE=True

# WorkOS Configuration (Google OAuth)
# Get these from https://dashboard.workos.com/
WORKOS_API_KEY=sk_test_REDACTED
WORKOS_CLIENT_ID=client_REDACTED
WORKOS_REDIRECT_URI=http://localhost:5173/auth/callback

# Google Gemini AI Configuration
# Get this from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Google Drive Configuration for Chat File Storage
# Set to True to use Google Drive, False to use local storage
USE_GOOGLE_DRIVE=False

# Google Drive Service Account Credentials (JSON format)
# Get this from Google Cloud Console > IAM & Admin > Service Accounts
# Download the JSON key file and paste its content here as a single line
# Example: {"type":"service_account","project_id":"your-project",...}
GOOGLE_DRIVE_CREDENTIALS_JSON=

# Optional: Folder ID where chat files will be stored
# Leave empty to store in root, or provide a folder ID from Google Drive
GOOGLE_DRIVE_FOLDER_ID=

# Set to True to make uploaded files publicly accessible (anyone with link can view)
GOOGLE_DRIVE_PUBLIC_FILES=True
